# Restaurant Management System - Configuração de Produção AWS
# IMPORTANTE: Este arquivo contém configurações de exemplo. 
# Configure as variáveis reais no AWS Systems Manager Parameter Store ou AWS Secrets Manager

# Environment
NODE_ENV=production

# Database (será configurado automaticamente pelo CloudFormation)
DATABASE_URL=postgresql://restaurant_admin:PASSWORD@RDS_ENDPOINT:5432/restaurant_management

# JWT Configuration
JWT_SECRET=restaurant-super-secret-production-key-2024
JWT_EXPIRES_IN=7d

# API Configuration
PORT=3001
API_VERSION=v1

# Frontend URLs (será configurado automaticamente)
FRONTEND_URL=https://CLOUDFRONT_DOMAIN
NEXT_PUBLIC_API_URL=https://ALB_DOMAIN

# AWS Configuration
AWS_REGION=us-east-1
AWS_S3_BUCKET=restaurant-management-frontend-ACCOUNT_ID

# CORS Configuration
CORS_ORIGIN=https://CLOUDFRONT_DOMAIN
CORS_CREDENTIALS=true

# Security
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Health Check
HEALTH_CHECK_ENABLED=true

# Cache (Redis será adicionado se necessário)
REDIS_URL=redis://elasticache-endpoint:6379
CACHE_TTL=3600

# File Upload
MAX_FILE_SIZE=10MB
UPLOAD_PATH=/app/uploads

# Email (configurar com SES se necessário)
EMAIL_PROVIDER=aws-ses
EMAIL_REGION=us-east-1

# Monitoring
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_BACKUP=true
ENABLE_CACHING=true

# Database Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_TIMEOUT=30000

# Session
SESSION_SECRET=restaurant-session-secret-2024
SESSION_TTL=86400 